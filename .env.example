# Server
PORT=3000
SESSION_SECRET=change-me-in-production

# PostgreSQL (omit for SQLite fallback)
SQL_DSN=postgres://aigateway:aigateway@localhost:5432/aigateway?sslmode=disable

# ClickHouse logging (omit CLICKHOUSE_DSN or set CLICKHOUSE_ENABLED=false to disable)
CLICKHOUSE_ENABLED=true
CLICKHOUSE_DSN=clickhouse://aigateway:aigateway@localhost:9000/ai_gateway
CLICKHOUSE_DATABASE=ai_gateway
CLICKHOUSE_RETENTION_DAYS=90
CLICKHOUSE_MAX_TEXT_BYTES=16384
CLICKHOUSE_MAX_JSON_BYTES=65536
CLICKHOUSE_BATCH_SIZE=500
CLICKHOUSE_FLUSH_INTERVAL=5s

# Debug
DEBUG=false
DEBUG_SQL=false
GIN_MODE=release
